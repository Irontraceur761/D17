# Sepolia reference configuration. Supply your own RPC endpoints.
CHAIN_ID=11155111
RPC_URL=https://your-sepolia-http-rpc.example
WS_URL=wss://your-sepolia-websocket-rpc.example
FACTORY_DEPLOYMENT_FILE=./deployments/sepolia.json

HOST=127.0.0.1
PORT=8787
INDEX_SOURCE_MODE=ws-logs
CONFIRMATIONS=2
LOG_CHUNK_SIZE=1000
RPC_CALL_TIMEOUT_MS=8000
RPC_RETRY_ATTEMPTS=3
RPC_MAX_REQUESTS_PER_SECOND=8
WS_GAP_BACKFILL_BLOCKS=25
WS_SAFETY_BACKFILL_MS=120000
REORG_LOOKBACK_BLOCKS=24
STATE_FILE=./data/state-sepolia.json
LOGO_DIR=./data/logos-sepolia

# Public API protections. Tighten these before exposing the service.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HTTP_RATE_LIMIT_WINDOW_MS=60000
HTTP_RATE_LIMIT_MAX=240
MAX_SSE_CLIENTS=25
MAX_WS_CLIENTS=25
WS_MAX_PAYLOAD_BYTES=1024
TRUST_PROXY_HEADERS=0
ALLOW_NOISY_API_EVENTS=0
WATCH_PAIR_EVENTS=0
EXCLUDED_INGEST_EVENTS=Swap,Sync,Transfer,Approval
SILENT_REALTIME_EVENTS=Swap,Sync,Transfer,Approval

# Hosted launch deployment is disabled by default.
MAINNET_HOSTED_DEPLOY_ENABLED=0
USD_PRICING_ENABLED=0
# Optional on Sepolia: a mainnet RPC used only for the Chainlink ETH/USD feed.
USD_PRICE_RPC_URL=
USD_PRICE_CACHE_MS=60000
USD_PRICE_STALE_SECONDS=3600
