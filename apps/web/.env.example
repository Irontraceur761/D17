# rpc reads directly from the selected network. api reads the optional local
# REST/WebSocket service. There is no silent fallback between modes.
NEXT_PUBLIC_D17_DATA_MODE=rpc
NEXT_PUBLIC_D17_DEFAULT_NETWORK=sepolia

# Direct RPC reads and deploy simulation. Fill the networks you intend to use.
NEXT_PUBLIC_D17_SEPOLIA_RPC_URL=https://your-sepolia-http-rpc.example
NEXT_PUBLIC_D17_SEPOLIA_RPC_WS_URL=wss://your-sepolia-websocket-rpc.example
NEXT_PUBLIC_D17_MAINNET_RPC_URL=https://your-mainnet-http-rpc.example
NEXT_PUBLIC_D17_MAINNET_RPC_WS_URL=wss://your-mainnet-websocket-rpc.example

# Optional indexed API mode. These local defaults match npm run api:all.
NEXT_PUBLIC_D17_SEPOLIA_API_BASE=http://127.0.0.1:8787
NEXT_PUBLIC_D17_SEPOLIA_WS_URL=ws://127.0.0.1:8787/api/ws
NEXT_PUBLIC_D17_MAINNET_API_BASE=http://127.0.0.1:8788
NEXT_PUBLIC_D17_MAINNET_WS_URL=ws://127.0.0.1:8788/api/ws

NEXT_PUBLIC_D17_SEPOLIA_EXPLORER_BASE=https://sepolia.etherscan.io
NEXT_PUBLIC_D17_MAINNET_EXPLORER_BASE=https://etherscan.io

# full exposes the participant and deploy routes from this one application.
NEXT_PUBLIC_SITE_MODE=full
NEXT_PUBLIC_ENABLE_DEPLOY=true
NEXT_PUBLIC_ENABLE_TEST_CONTROLS=false
NEXT_PUBLIC_ENABLE_USD=false

# Optional initial launch and event-start overrides for focused local testing.
NEXT_PUBLIC_D17_SEPOLIA_LAUNCH_ADDRESS=
NEXT_PUBLIC_D17_SEPOLIA_FROM_BLOCK=
NEXT_PUBLIC_D17_MAINNET_LAUNCH_ADDRESS=
NEXT_PUBLIC_D17_MAINNET_FROM_BLOCK=

# Optional standalone ETH/USD reference endpoint per network (D17 price
# envelope). USD renders whenever a provider is configured AND ENABLE_USD is
# not false: api mode defaults to the indexed API's /api/prices/eth-usd; rpc
# mode stays off unless one of these is set. The browser never reads an
# oracle or RPC for pricing.
NEXT_PUBLIC_D17_SEPOLIA_PRICE_URL=
NEXT_PUBLIC_D17_MAINNET_PRICE_URL=
