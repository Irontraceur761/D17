# Never commit a populated copy of this file.
RPC_URL=https://your-mainnet-rpc.example
D17_EXPECTED_CHAIN_ID=1

# Canonical Ethereum mainnet addresses.
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Deployment scripts require locally supplied funded signers.
D17_FACTORY_PRIVATE_KEY=
D17_LOCKER_FACTORY_PRIVATE_KEY=
# Optional. Defaults to D17_FACTORY_PRIVATE_KEY when unset.
D17_LAUNCH_FACTORY_PRIVATE_KEY=

# Renounce only after every pin transaction has succeeded and been checked.
RENOUNCE_D17_FACTORY_OWNER=1
# Required in addition to the canonical-address checks before a mainnet deployment.
D17_CONFIRM_MAINNET_DEPLOY=0
ALLOW_SHARED_DEPLOYER=0
RPC_BATCH_MAX_COUNT=1

# create-launch.mjs
TOKEN_DEPLOYER_PRIVATE_KEY=
FACTORY_ADDRESS=0x4103c658141447DFc3a70aE2D5C7a5Ad8d970844
TREASURY_ADDRESS=
